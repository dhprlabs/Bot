      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: false
      Tree:
        base_footprint:
          base_link:
            bk_left_wheel_link:
              {}
            bk_right_wheel_link:
              {}
            camera_link:
              {}
            fr_left_wheel_link:
              {}
            fr_right_wheel_link:
              {}
            lidar_link:
              {}
        odom:
          {}
      Update Interval: 0
