        base_link:
          Value: true
        bk_left_wheel_link:
          Value: true
        bk_right_wheel_link:
          Value: true
        camera_link:
          Value: true
        fr_left_wheel_link:
          Value: true
        fr_right_wheel_link:
          Value: true
        lidar_link:
          Value: true
        odom:
          Value: true
